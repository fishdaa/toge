{
  "$schema": "https://raw.githubusercontent.com/nicholasrice/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Toge",
  "version": "0.1.11",
  "identifier": "net.fishda.toge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Toge",
        "width": 960,
        "height": 640,
        "minWidth": 480,
        "minHeight": 320,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-dev"]
      }
    }
  }
}
