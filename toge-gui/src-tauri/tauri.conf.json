{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Toge",
  "version": "0.1.15",
  "identifier": "net.fishda.toge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Toge",
        "width": 960,
        "height": 640,
        "minWidth": 480,
        "minHeight": 320,
        "resizable": true,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm",
      "appimage"
    ],
    "homepage": "https://github.com/fishdaa/needle",
    "category": "Utility",
    "shortDescription": "Fast local file search for Linux",
    "longDescription": "Toge is a fast, daemon-backed local file search application for Linux.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/bin/toge": "../../target/release/toge",
          "/usr/bin/toged": "../../target/release/toged"
        }
      },
      "rpm": {
        "files": {
          "/usr/bin/toge": "../../target/release/toge",
          "/usr/bin/toged": "../../target/release/toged"
        }
      },
      "appimage": {
        "files": {
          "/usr/bin/toge": "../../target/release/toge",
          "/usr/bin/toged": "../../target/release/toged"
        }
      }
    }
  }
}
